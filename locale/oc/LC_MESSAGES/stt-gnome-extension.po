#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Reïnicializar per defaut"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Vòtz en tèxte"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "Provesidor OpenRouter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"Credencials API e paramètres del modèl per la transcripcion via OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "Clau API"

#: src/prefs.ts:71
msgid "Model"
msgstr "Modèl"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Temperatura"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Temperatura d'escondonatge (0 = deterministic, 1 = mai creatiu)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Temps d'espera de la demanda"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Segondas d'espera per la transcripcion"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Comportament"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Mostrar l'icòna dins la barra superiora"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Quand l’opcion es desactivada, l’icòna apareis pas que durant l’enregistrament o la transcripcion."

#: src/prefs.ts:126
msgid "Left"
msgstr "Esquèrra"

#: src/prefs.ts:127
msgid "Center"
msgstr "Centre"

#: src/prefs.ts:128
msgid "Right"
msgstr "Dreita"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Alinhament orizontal de la safata"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Metre l’icòna d’estat dins la seccion esquèrra, centrala o drecha de la barra superiora."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Posicion de l’icòna sus la barra"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Òrdre dins aquesta seccion (− / +): valor mai nauta = mai pròche del bòrd extèrne de la barra."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Pegar lo tèxt de reemplaçament"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Far pas res (sens quichapapièrs / pegada)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Quand i a pas de paraula"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Se lo modèl torna pas cap de mot transcrit"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Tèxt de reemplaçament (per ex. …; daissar void per pas pegar res)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Jogar d'efièches sonòrs"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Emetre un son al començament e a l'arrèst de l'enregistrament"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Volum sonòr"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Volum dels efièches de començament/arrèst (0 = mut, 100 = plen)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Acorchi de clavièr"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Quichatz sus una combinason de tòcas ont que siá per aviar o arrestar "
"l'enregistrament."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Activar los acorchis de clavièr"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr ""
"Quand es desactivat, lo acorchi de basculament d'enregistrament es inactiu"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Bascular l'enregistrament"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Desactivat"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Quichatz sus l'acorchi…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr ""
"Mercés de configurar vòstra clau API OpenRouter dins los paramètres de "
"l'extension."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr ""
"Mercés de definir un modèl de transcripcion dins los paramètres de "
"l'extension."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Vòtz en tèxte — Error"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Fracàs del començament de l'enregistrament."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr ""
#~ "Mercés de definir una indicacion del sistèma dins los paramètres de "
#~ "l'extension."

#~ msgid "System Prompt"
#~ msgstr "Indicacion del sistèma"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Icòna del microfòn totjorn visibla dins lo panèl. Quand es amagada, "
#~ "l'icòna apareis pendent l'enregistrament."

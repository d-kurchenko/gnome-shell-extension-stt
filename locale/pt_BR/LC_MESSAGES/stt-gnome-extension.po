#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Restaurar padrão"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Voz para texto"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "Provedor OpenRouter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"Credenciais da API e configurações do modelo para transcrição via OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "Chave API"

#: src/prefs.ts:71
msgid "Model"
msgstr "Modelo"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Temperatura"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Temperatura de amostragem (0 = determinístico, 1 = mais criativo)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Tempo limite da solicitação"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Segundos de espera para transcrição"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Comportamento"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Mostrar ícone na barra superior"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Quando desativado, o ícone aparece apenas durante a gravação ou a transcrição."

#: src/prefs.ts:126
msgid "Left"
msgstr "Esquerda"

#: src/prefs.ts:127
msgid "Center"
msgstr "Centro"

#: src/prefs.ts:128
msgid "Right"
msgstr "Direita"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Alinhamento horizontal da bandeja"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Coloque o ícone de status na seção esquerda, central ou direita da barra superior."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Posição do ícone na barra"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Ordem nessa seção (− / +): valor maior = mais próximo da borda externa da barra."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Colar texto de espaço reservado"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Não fazer nada (sem área de transferência / colagem)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Quando não há fala"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Se o modelo não retornar palavras transcritas"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Texto de espaço reservado (ex.: …; deixe vazio para não colar nada)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Reproduzir efeitos sonoros"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Reproduzir tom ao iniciar e parar a gravação"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Volume do som"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Volume para efeitos de início/parada (0 = mudo, 100 = máximo)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Atalho de teclado"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Pressione uma combinação de teclas em qualquer lugar para iniciar ou parar a "
"gravação."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Habilitar atalhos de teclado"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Quando desligado, a tecla de atalho de gravação fica inativa"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Alternar gravação"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Desativado"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Pressione o atalho…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr ""
"Por favor, configure sua chave API do OpenRouter nas configurações da "
"extensão."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr ""
"Por favor, defina um modelo de transcrição nas configurações da extensão."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Voz para texto — Erro"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Falha ao iniciar a gravação."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr ""
#~ "Por favor, defina um prompt de sistema nas configurações da extensão."

#~ msgid "System Prompt"
#~ msgstr "Prompt do sistema"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Ícone do microfone sempre visível no painel. Quando oculto, o ícone "
#~ "aparece durante a gravação."

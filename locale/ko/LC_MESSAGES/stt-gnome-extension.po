#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "기본값으로 재설정"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "음성을 텍스트로"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "OpenRouter 제공자"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr "OpenRouter를 통한 전사를 위한 API 자격 증명 및 모델 설정."

#: src/prefs.ts:65
msgid "API Key"
msgstr "API 키"

#: src/prefs.ts:71
msgid "Model"
msgstr "모델"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "온도"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "샘플링 온도 (0 = 결정적, 1 = 더 창의적)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "요청 시간 초과"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "전사 대기 시간(초)"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "동작"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "상단 표시줄에 아이콘 표시"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "끄면 녹음 또는 받아쓰기 중에만 아이콘이 표시됩니다."

#: src/prefs.ts:126
msgid "Left"
msgstr "왼쪽"

#: src/prefs.ts:127
msgid "Center"
msgstr "가운데"

#: src/prefs.ts:128
msgid "Right"
msgstr "오른쪽"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "트레이 가로 정렬"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "상단 표시줄의 왼쪽, 가운데 또는 오른쪽 영역에 상태 아이콘을 배치합니다."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "표시줄의 아이콘 위치"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "해당 영역 안에서 순서(− / +): 값이 클수록 표시줄 바깥쪽 가장자리에 가깝습니다."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "자리 표시자 텍스트 붙여넣기"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "아무 작업도 하지 않음(클립보드/붙여넣기 없음)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "음성이 없을 때"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "모델이 받아쓴 단어를 반환하지 않으면"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "자리 표시자 텍스트(예: …; 비워 두면 아무 것도 붙여넣지 않음)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "음향 효과 재생"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "녹음 시작 및 중지 시 신호음 재생"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "음량"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "시작/중지 효과 볼륨 (0 = 음소거, 100 = 최대)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "키보드 단축키"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr "어디서든 키 조합을 눌러 녹음을 시작하거나 중지하세요."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "키보드 단축키 활성화"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "꺼져 있으면 녹음 전환 단축키가 비활성화됩니다"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "녹음 전환"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "비활성화됨"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "단축키를 누르세요…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr "확장 프로그램 설정에서 OpenRouter API 키를 설정하세요."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "확장 프로그램 설정에서 전사 모델을 설정하세요."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "음성을 텍스트로 — 오류"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "녹음을 시작하지 못했습니다."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr "확장 프로그램 설정에서 시스템 프롬프트를 설정하세요."

#~ msgid "System Prompt"
#~ msgstr "시스템 프롬프트"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "마이크 아이콘이 항상 패널에 표시됩니다. 숨겨져 있어도 녹음 중에는 아이콘"
#~ "이 나타납니다."

#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Скинути до стандартного"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Голос у текст"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "Провайдер OpenRouter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"Облікові дані API та налаштування моделі для транскрипції через OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "Ключ API"

#: src/prefs.ts:71
msgid "Model"
msgstr "Модель"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Температура"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Температура семплювання (0 = детерміновано, 1 = більш креативно)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Таймаут запиту"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Секунд очікування транскрипції"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Поведінка"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Показувати іконку у верхній панелі"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr ""
"Коли вимкнено, іконка показується лише під час запису або транскрипції."

#: src/prefs.ts:126
msgid "Left"
msgstr "Ліворуч"

#: src/prefs.ts:127
msgid "Center"
msgstr "По центру"

#: src/prefs.ts:128
msgid "Right"
msgstr "Праворуч"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Горизонтальне вирівнювання в треї"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Розмістити значок стану в лівій, центральній або правій частині верхньої панелі."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Позиція значка на панелі"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Порядок у цій області (− / +): більше значення — ближче до зовнішнього краю панелі."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Вставити текст-заповнювач"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Нічого не робити (без буфера обміну / вставки)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Коли мовлення немає"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Якщо модель не повернула жодного слова транскрипції"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr ""
"Текст-заповнювач (напр. …; залиште порожнім, щоб нічого не вставляти)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Відтворювати звукові ефекти"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Відтворювати звук при старті та зупинці запису"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Гучність звуку"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Гучність ефектів старту/зупинки (0 = без звуку, 100 = максимум)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Комбінація клавіш"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr "Натисніть комбінацію клавіш будь-де, щоб почати або зупинити запис."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Увімкнути комбінації клавіш"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Коли вимкнено, гаряча клавіша перемикання запису неактивна"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Перемкнути запис"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Вимкнено"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Натисніть комбінацію…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr ""
"Будь ласка, вкажіть свій ключ OpenRouter API у налаштуваннях розширення."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "Будь ласка, вкажіть модель транскрипції у налаштуваннях розширення."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Голос у текст — Помилка"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Не вдалося розпочати запис."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr "Будь ласка, вкажіть системний промпт у налаштуваннях розширення."

#~ msgid "System Prompt"
#~ msgstr "Системний промпт"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Іконка мікрофона завжди видна в панелі. Коли прихована, іконка "
#~ "з'являється під час запису."

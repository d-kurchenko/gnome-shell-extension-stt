#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Palauta oletus"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Puhe tekstiksi"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "OpenRouter-palveluntarjoaja"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"API-tunnistetiedot ja malliasetukset transkriptioon OpenRouterin kautta."

#: src/prefs.ts:65
msgid "API Key"
msgstr "API-avain"

#: src/prefs.ts:71
msgid "Model"
msgstr "Malli"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Lämpötila"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Näytteenoton lämpötila (0 = deterministinen, 1 = luovempi)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Pyynnön aikakatkaisu"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Sekuntia odotusta transkriptioon"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Käyttäytyminen"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Näytä kuvake yläpalkissa"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Kun pois päältä, kuvake näkyy vain tallennuksen tai litteroinnin aikana."

#: src/prefs.ts:126
msgid "Left"
msgstr "Vasen"

#: src/prefs.ts:127
msgid "Center"
msgstr "Keskellä"

#: src/prefs.ts:128
msgid "Right"
msgstr "Oikea"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Ilmoitusalueen vaakasuora tasaus"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Sijoita tilakuvake yläpalkin vasempaan, keskimmäiseen tai oikeaan osaan."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Kuvakkeen sijainti palkissa"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Järjestys tässä osassa (− / +): suurempi = lähempänä palkin ulkoreunaa."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Liitä paikkamerkkiteksti"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Älä tee mitään (ei leikepöytää / liittämistä)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Kun puhetta ei ole"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Jos malli ei palauta litteroituja sanoja"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Paikkamerkkiteksti (esim. …; jätä tyhjäksi ettei liitetä mitään)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Toista ääniefektit"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Toista ääni tallennuksen alkaessa ja päättyessä"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Äänenvoimakkuus"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr ""
"Äänenvoimakkuus aloitus-/lopetusefekteille (0 = mykistetty, 100 = täysi)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Näppäinoikotie"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Paina näppäinyhdistelmää missä tahansa aloittaaksesi tai lopettaaksesi "
"tallennuksen."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Ota näppäinoikotiet käyttöön"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Kun pois päältä, tallennuksen vaihtonäppäin on epäaktiivinen"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Vaihda tallennus"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Ei käytössä"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Paina pikanäppäintä…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr "Aseta OpenRouter API-avaimesi laajennuksen asetuksissa."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "Aseta transkriptiomalli laajennuksen asetuksissa."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Puhe tekstiksi — Virhe"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Tallennuksen aloitus epäonnistui."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr "Aseta järjestelmäkehotus laajennuksen asetuksissa."

#~ msgid "System Prompt"
#~ msgstr "Järjestelmäkehotus"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Mikrofonikuvake aina näkyvissä paneelissa. Piilotettuna kuvake näkyy "
#~ "tallennuksen aikana."

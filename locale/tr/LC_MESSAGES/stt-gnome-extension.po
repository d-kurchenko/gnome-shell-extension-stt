#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Varsayılana sıfırla"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Sesli Metin"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "OpenRouter Sağlayıcı"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"OpenRouter üzerinden transkripsiyon için API kimlik bilgileri ve model "
"ayarları."

#: src/prefs.ts:65
msgid "API Key"
msgstr "API Anahtarı"

#: src/prefs.ts:71
msgid "Model"
msgstr "Model"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Sıcaklık"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Örnekleme sıcaklığı (0 = belirlenimci, 1 = daha yaratıcı)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "İstek Zaman Aşımı"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Transkripsiyon için beklenecek saniye"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Davranış"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Üst Çubukta Simgeyi Göster"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Kapalıyken simge yalnızca kayıt veya çeviri sırasında görünür."

#: src/prefs.ts:126
msgid "Left"
msgstr "Sol"

#: src/prefs.ts:127
msgid "Center"
msgstr "Orta"

#: src/prefs.ts:128
msgid "Right"
msgstr "Sağ"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Tepsi yatay hizalaması"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Durum simgesini üst çubuğun sol, orta veya sağ bölümüne yerleştirin."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Çubuktaki simge konumu"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Bu bölüm içinde sıra (− / +): daha yüksek = çubuğun dış kenarına daha yakın."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Yer tutucu metni yapıştır"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Hiçbir şey yapma (pano / yapıştırma yok)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Konuşma yoksa"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Model çözümlenmiş sözcük döndürmezse"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Yer tutucu metin (örn. …; yapıştırmamak için boş bırakın)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Ses Efektlerini Oynat"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Kayıt başladığında ve durduğunda ses çal"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Ses Seviyesi"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Başlatma/durdurma efektleri için ses seviyesi (0 = sessiz, 100 = tam)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Klavye Kısayolu"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Kaydı başlatmak veya durdurmak için herhangi bir yerde bir tuş "
"kombinasyonuna basın."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Klavye Kısayollarını Etkinleştir"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Kapalıyken, kayıt değiştirme kısayol tuşu etkin değildir"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Kaydı Aç/Kapat"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Devre Dışı"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Kısayola basın…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr "Lütfen OpenRouter API anahtarınızı eklenti ayarlarından yapılandırın."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "Lütfen eklenti ayarlarında bir transkripsiyon modeli belirleyin."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Sesli Metin — Hata"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Kayıt başlatılamadı."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr "Lütfen eklenti ayarlarında bir sistem istemi belirleyin."

#~ msgid "System Prompt"
#~ msgstr "Sistem İstemi"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Mikrofon simgesi panelde her zaman görünür. Gizlendiğinde, kayıt "
#~ "sırasında simge görünür."

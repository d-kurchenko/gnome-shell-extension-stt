#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Leheneratu"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Ahotsa testura"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "OpenRouter hornitzailea"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"API kredentzialak eta modeloaren ezarpenak OpenRouter bidezko "
"transkripziorako."

#: src/prefs.ts:65
msgid "API Key"
msgstr "API gakoa"

#: src/prefs.ts:71
msgid "Model"
msgstr "Eredua"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Tenperatura"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Laginketa-tenperatura (0 = determinista, 1 = sortzaileagoa)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Eskaeraren denbora-muga"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Transkripzioa itxaroteko segundoak"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Portaera"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Erakutsi ikonoa goiko barran"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Desaktibatuta badago, ikonoa grabazioa edo transkripzioa dagoenean bakarrik agertzen da."

#: src/prefs.ts:126
msgid "Left"
msgstr "Ezkerrean"

#: src/prefs.ts:127
msgid "Center"
msgstr "Erdian"

#: src/prefs.ts:128
msgid "Right"
msgstr "Eskuinean"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Erretiluaren lerrokatze horizontala"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Kokatu egoera-ikonoa goiko barraren ezker, erdi edo eskuin atalean."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Ikonoaren posizioa barran"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Atal horretan ordena (− / +): handiagoa = barraren kanpoaldeko ertzetik gertuago."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Tokiko testua itsatsi"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Ezer ez egitea (arbelik / itsasteik gabe)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Hizketarik ez dagoenean"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Ereduak ez baditu hitz transkribaturik itzultzen"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Tokiko testua (adib. …; utzi hutsik ez itsatzeko ezer)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Soinu-efektuak erreproduzitu"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Erreproduzitu doinua grabazioa hasi eta gelditzean"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Soinu-bolumena"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Hasiera/gelditze efektuen bolumena (0 = mutu, 100 = maximoa)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Teklatu-lasterbidea"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr "Sakatu teklatu-konbinazio bat edonon grabazioa hasteko edo gelditzeko."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Gaitu teklatu-lasterbideak"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Itzalita dagoenean, grabazioa aldatzeko tekla inaktibo dago"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Txandakatu grabazioa"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Desgaituta"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Sakatu lasterbidea…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr "Mesedez, ezarri zure OpenRouter API gakoa luzapenaren ezarpenetan."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "Mesedez, ezarri transkripzio-eredu bat luzapenaren ezarpenetan."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Ahotsa testura — Errorea"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Ezin izan da grabazioa hasi."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr "Mesedez, ezarri sistemaren gonbita bat luzapenaren ezarpenetan."

#~ msgid "System Prompt"
#~ msgstr "Sistemaren gonbita"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Mikrofonoaren ikonoa beti ikusgai panelean. Ezkutatuta dagoenean, ikonoa "
#~ "grabazioan agertzen da."

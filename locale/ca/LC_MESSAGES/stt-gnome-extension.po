#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Restableix al valor per defecte"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Veu a text"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "Proveïdor OpenRouter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"Credencials API i configuració del model per a la transcripció via "
"OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "Clau API"

#: src/prefs.ts:71
msgid "Model"
msgstr "Model"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Temperatura"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Temperatura de mostreig (0 = determinista, 1 = més creatiu)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Temps d'espera de la sol·licitud"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Segons d'espera per a la transcripció"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Comportament"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Mostra la icona a la barra superior"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Si està desactivada, la icona només apareix durant la gravació o la transcripció."

#: src/prefs.ts:126
msgid "Left"
msgstr "Esquerra"

#: src/prefs.ts:127
msgid "Center"
msgstr "Centre"

#: src/prefs.ts:128
msgid "Right"
msgstr "Dreta"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Alineació horitzontal de la safata"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Col·loca la icona d’estat a la secció esquerra, central o dreta de la barra superior."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Posició de la icona a la barra"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Ordre dins d’aquesta secció (− / +): valor més alt = més a prop de la vora exterior de la barra."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Enganxa text marcador de posició"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "No fer res (sense porta-retalls / enganxat)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Quan no hi ha veu"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Si el model no retorna paraules transcrites"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Text marcador (p. ex. …; deixeu buit per no enganxar res)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Reprodueix efectes de so"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Reprodueix un to quan l'enregistrament comença i s'atura"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Volum del so"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Volum per als efectes d'inici/aturada (0 = silenci, 100 = màxim)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Drecera de teclat"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Premeu una combinació de tecles a qualsevol lloc per iniciar o aturar "
"l'enregistrament."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Habilita les dreceres de teclat"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr ""
"Quan està desactivat, la tecla de commutació d'enregistrament està inactiva"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Commuta l'enregistrament"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Desactivat"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Premeu la drecera…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr ""
"Si us plau, configura la clau API d'OpenRouter a la configuració de "
"l'extensió."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr ""
"Si us plau, configura un model de transcripció a la configuració de "
"l'extensió."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Veu a text — Error"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "No s'ha pogut iniciar l'enregistrament."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr ""
#~ "Si us plau, configura una indicació del sistema a la configuració de "
#~ "l'extensió."

#~ msgid "System Prompt"
#~ msgstr "Indicació del sistema"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Icona del micròfon sempre visible al panell. Quan està amagada, la icona "
#~ "apareix durant l'enregistrament."

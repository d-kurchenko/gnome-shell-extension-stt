#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Auf Standard zurücksetzen"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Sprache zu Text"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "OpenRouter-Anbieter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"API-Anmeldedaten und Modelleinstellungen für die Transkription über "
"OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "API-Schlüssel"

#: src/prefs.ts:71
msgid "Model"
msgstr "Modell"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Temperatur"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Sampling-Temperatur (0 = deterministisch, 1 = kreativer)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Anfrage-Timeout"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Wartezeit in Sekunden für die Transkription"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Verhalten"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Symbol in oberer Leiste anzeigen"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Wenn ausgeschaltet, wird das Symbol nur während der Aufnahme oder Transkription angezeigt."

#: src/prefs.ts:126
msgid "Left"
msgstr "Links"

#: src/prefs.ts:127
msgid "Center"
msgstr "Mitte"

#: src/prefs.ts:128
msgid "Right"
msgstr "Rechts"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Horizontale Tray-Ausrichtung"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Statussymbol in der linken, mittleren oder rechten Zone der oberen Leiste platzieren."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Symbolposition in der Leiste"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Reihenfolge in diesem Bereich (− / +): höher = näher am äußeren Rand der Leiste."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Platzhaltertext einfügen"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Nichts tun (keine Zwischenablage / kein Einfügen)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Wenn keine Sprache erkannt wird"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Wenn das Modell keine transkribierten Wörter zurückgibt"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Platzhaltertext (z. B. …; leer lassen, um nichts einzufügen)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Soundeffekte abspielen"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Ton bei Start und Stopp der Aufnahme abspielen"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Lautstärke"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Lautstärke für Start/Stopp-Effekte (0 = stumm, 100 = voll)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Tastenkombination"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Drücken Sie eine Tastenkombination an beliebiger Stelle, um die Aufnahme zu "
"starten oder zu stoppen."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Tastenkombinationen aktivieren"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr "Wenn deaktiviert, ist die Aufnahme-Umschalttaste inaktiv"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Aufnahme umschalten"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Deaktiviert"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Tastenkombination drücken…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr ""
"Bitte geben Sie Ihren OpenRouter API-Schlüssel in den "
"Erweiterungseinstellungen an."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr ""
"Bitte legen Sie ein Transkriptionsmodell in den Erweiterungseinstellungen "
"fest."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Sprache zu Text — Fehler"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Aufnahme konnte nicht gestartet werden."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr ""
#~ "Bitte legen Sie einen System-Prompt in den Erweiterungseinstellungen fest."

#~ msgid "System Prompt"
#~ msgstr "System-Prompt"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Mikrofonsymbol immer im Panel sichtbar. Wenn ausgeblendet, erscheint das "
#~ "Symbol während der Aufnahme."

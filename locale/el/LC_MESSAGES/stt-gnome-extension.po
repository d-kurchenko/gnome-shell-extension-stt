#: src/prefs.ts:19 src/prefs.ts:286
msgid "Reset to default"
msgstr "Επαναφορά στην προεπιλογή"

#: src/prefs.ts:53 src/extension.ts:688 src/extension.ts:697
msgid "Speech to Text"
msgstr "Φωνή σε κείμενο"

#: src/prefs.ts:59
msgid "OpenRouter Provider"
msgstr "Πάροχος OpenRouter"

#: src/prefs.ts:60
msgid "API credentials and model settings for transcription via OpenRouter."
msgstr ""
"Διαπιστευτήρια API και ρυθμίσεις μοντέλου για μεταγραφή μέσω OpenRouter."

#: src/prefs.ts:65
msgid "API Key"
msgstr "Κλειδί API"

#: src/prefs.ts:71
msgid "Model"
msgstr "Μοντέλο"

#: src/prefs.ts:83
msgid "Temperature"
msgstr "Θερμοκρασία"

#: src/prefs.ts:84
msgid "Sampling temperature (0 = deterministic, 1 = more creative)"
msgstr "Θερμοκρασία δειγματοληψίας (0 = ντετερμινιστική, 1 = πιο δημιουργική)"

#: src/prefs.ts:97
msgid "Request Timeout"
msgstr "Χρονικό όριο αιτήματος"

#: src/prefs.ts:98
msgid "Seconds to wait for transcription"
msgstr "Δευτερόλεπτα αναμονής για μεταγραφή"

#: src/prefs.ts:110
msgid "Behavior"
msgstr "Συμπεριφορά"

#: src/prefs.ts:115
msgid "Show Icon in Top Bar"
msgstr "Εμφάνιση εικονιδίου στην επάνω μπάρα"

#: src/prefs.ts:116
msgid "When off, the icon appears only while recording or transcribing."
msgstr "Όταν είναι ανενεργό, το εικονίδιο εμφανίζεται μόνο κατά την εγγραφή ή τη μεταγραφή."

#: src/prefs.ts:126
msgid "Left"
msgstr "Αριστερά"

#: src/prefs.ts:127
msgid "Center"
msgstr "Κέντρο"

#: src/prefs.ts:128
msgid "Right"
msgstr "Δεξιά"

#: src/prefs.ts:131
msgid "Tray Horizontal Alignment"
msgstr "Οριζόντια στοίχιση στη γραμμή κατάστασης"

#: src/prefs.ts:132
msgid ""
"Place the status icon in the left, center, or right section of the top bar."
msgstr "Τοποθετήστε το εικονίδιο κατάστασης στο αριστερό, κεντρικό ή δεξί τμήμα της επάνω γραμμής."

#: src/prefs.ts:172
msgid "Top Bar Icon Position"
msgstr "Θέση εικονιδίου στη γραμμή"

#: src/prefs.ts:173
msgid ""
"Order within that section (− / +): higher = closer to the outer edge of the "
"bar."
msgstr "Σειρά εντός αυτού του τμήματος (− / +): υψηλότερη τιμή = πιο κοντά στην εξωτερική άκρη της γραμμής."

#: src/prefs.ts:187
msgid "Paste placeholder text"
msgstr "Επικόλληση κειμένου υποκαταστάτου"

#: src/prefs.ts:188
msgid "Do nothing (no clipboard / paste)"
msgstr "Να μην γίνεται τίποτα (χωρίς πρόχειρο / επικόλληση)"

#: src/prefs.ts:191
msgid "When there is no speech"
msgstr "Όταν δεν υπάρχει ομιλία"

#: src/prefs.ts:192
msgid "If the model returns no transcribed words"
msgstr "Αν το μοντέλο δεν επιστρέψει μεταγραμμένες λέξεις"

#: src/prefs.ts:222
msgid "Placeholder text (e.g. …; leave empty to paste nothing)"
msgstr "Κείμενο υποκαταστάτου (π.χ. …; αφήστε κενό για να μην επικολληθεί τίποτα)"

#: src/prefs.ts:247
msgid "Play Sound Effects"
msgstr "Αναπαραγωγή ηχητικών εφέ"

#: src/prefs.ts:248
msgid "Play tone when recording starts and stops"
msgstr "Αναπαραγωγή ήχου κατά την έναρξη και διακοπή της εγγραφής"

#: src/prefs.ts:254
msgid "Sound Volume"
msgstr "Ένταση ήχου"

#: src/prefs.ts:255
msgid "Volume for start/stop effects (0 = mute, 100 = full)"
msgstr "Ένταση για εφέ έναρξης/διακοπής (0 = σίγαση, 100 = πλήρης)"

#: src/prefs.ts:267
msgid "Keyboard Shortcut"
msgstr "Συντόμευση πληκτρολογίου"

#: src/prefs.ts:268
msgid "Press a key combination anywhere to start or stop recording."
msgstr ""
"Πατήστε ένα συνδυασμό πλήκτρων οπουδήποτε για έναρξη ή διακοπή της εγγραφής."

#: src/prefs.ts:273
msgid "Enable Keyboard Shortcuts"
msgstr "Ενεργοποίηση συντομεύσεων πληκτρολογίου"

#: src/prefs.ts:274
msgid "When off, the toggle-recording shortcut is inactive."
msgstr ""
"Όταν είναι απενεργοποιημένο, το πλήκτρο εναλλαγής εγγραφής είναι ανενεργό"

#: src/prefs.ts:280
msgid "Toggle Recording"
msgstr "Εναλλαγή εγγραφής"

#: src/prefs.ts:304 src/prefs.ts:342
msgid "Disabled"
msgstr "Απενεργοποιημένο"

#: src/prefs.ts:362
msgid "Press shortcut…"
msgstr "Πατήστε συντόμευση…"

#: src/extension.ts:689
msgid "Please set your OpenRouter API key in extension settings."
msgstr "Παρακαλώ ορίστε το κλειδί OpenRouter API στις ρυθμίσεις της επέκτασης."

#: src/extension.ts:698
msgid "Please set a transcription model in extension settings."
msgstr "Παρακαλώ ορίστε ένα μοντέλο μεταγραφής στις ρυθμίσεις της επέκτασης."

#: src/extension.ts:718 src/extension.ts:791
msgid "Speech to Text — Error"
msgstr "Φωνή σε κείμενο — Σφάλμα"

#: src/extension.ts:719
msgid "Failed to start recording."
msgstr "Αποτυχία έναρξης εγγραφής."

#~ msgid "Please set a system prompt in extension settings."
#~ msgstr ""
#~ "Παρακαλώ ορίστε μια προτροπή συστήματος στις ρυθμίσεις της επέκτασης."

#~ msgid "System Prompt"
#~ msgstr "Προτροπή συστήματος"

#~ msgid ""
#~ "Microphone icon always visible in panel. When hidden, icon still appears "
#~ "during recording."
#~ msgstr ""
#~ "Το εικονίδιο μικροφώνου είναι πάντα ορατό στον πίνακα. Όταν είναι κρυφό, "
#~ "εμφανίζεται κατά την εγγραφή."
